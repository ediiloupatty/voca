# Salin file ini menjadi .env lalu isi API key kamu.
# API key Qwen / Alibaba Model Studio.
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# Base URL endpoint OpenAI-compatible DashScope (internasional).
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# (Opsional) Provider lain — Qwen tetap default. Ganti saat jalan lewat menu
# /model (pilih provider -> pilih model, daftar diambil live) atau dengan
# mengetik nama provider: 'gpt', 'router', 'gemini', 'grok', 'groq',
# 'mistral', 'deepseek', 'ollama', 'qwen'. Isi key yang sesuai untuk aktif.
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxx
# OPENAI_MODEL=gpt-4o
# OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx   # 1 key = Claude, GPT, Gemini, Grok, dll.
# OPENROUTER_MODEL=openai/gpt-4o     # slug bebas dari openrouter.ai/models
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
# DEEPSEEK_MODEL=deepseek-v4-flash   # lebih cepat; deepseek-v4-pro lebih pintar tapi lambat
# DEEPSEEK_THINKING=1                # 1=mode berpikir, 0=cepat tanpa thinking
# GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxx             # aistudio.google.com/apikey
# GEMINI_MODEL=gemini-2.5-flash
# XAI_API_KEY=xai-xxxxxxxxxxxxxxxxxxxx                # console.x.ai (Grok)
# XAI_MODEL=grok-4
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx               # console.groq.com/keys
# GROQ_MODEL=llama-3.3-70b-versatile
# MISTRAL_API_KEY=xxxxxxxxxxxxxxxxxxxx                # console.mistral.ai/api-keys
# MISTRAL_MODEL=mistral-large-latest
# OLLAMA_API_KEY=ollama              # LLM lokal/offline — cukup placeholder ini
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.2
# VOCA_PROVIDER=qwen        # default saat start: qwen / openai / openrouter / deepseek
# VOCA_LANG=en              # bahasa default saat start: en (English) / id (Indonesia).
#                           # Default English. Bisa diganti saat jalan via '/lan'.
# MIN_SPEECH_RMS=0.003      # Sensitivitas suara (lebih kecil = lebih sensitif, default: 0.003)
